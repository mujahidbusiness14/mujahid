rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isAdmin() {
      // In this environment, we can check for specific emails or a global admin collection
      // For now, only the project owner (mujahidbusiness14@gmail.com) is admin
      return isSignedIn() && request.auth.token.email == "mujahidbusiness14@gmail.com" && request.auth.token.email_verified == true;
    }

    // Consultation Requests
    match /consultation_requests/{requestId} {
      allow create: if isValidConsultationRequest(incoming());
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    function isValidConsultationRequest(data) {
      return data.keys().hasAll(['name', 'clinicName', 'email', 'phone', 'message', 'createdAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.clinicName is string && data.clinicName.size() > 0 && data.clinicName.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 20
        && data.message is string && data.message.size() > 0 && data.message.size() <= 2000
        && data.createdAt == request.time;
    }
  }
}
